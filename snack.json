{
  "$schema": "./node_modules/@snack-game/cli/snack.schema.json",
  "version": 1,
  "assets": {
    "directory": "assets"
  },
  "server": {
    "entry": "src/server.ts"
  },
  "client": {
    "entry": "src/client.ts"
  },
  "game": {
    "titleImage": "snack.svg",
    "maxPlayers": {
      "lowerLimit": 1,
      "upperLimit": 32,
      "default": 32
    },
    "serverConfigSchema": {
      "botFill": {
        "type": "number",
        "default": 8,
        "label": "Bot fill",
        "description": "Target combatant count filled by bots. Set to 0 to run without bots."
      }
    },
    "name": "Startrace",
    "platforms": ["desktop", "phone", "tablet"],
    "visibility": "private"
  }
}
