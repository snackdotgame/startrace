    "name": "Star Trace",
    "genre": "shooter",
    "platforms": ["desktop", "phone", "tablet"],
    "visibility": "public",
    "slug": "star-trace",
    "id": "4854ac94-d242-499d-97d6-1547302aee37",
    "versionId": "e2e214e5-247e-4a73-89de-6d38b2f4c2f5"
  }
